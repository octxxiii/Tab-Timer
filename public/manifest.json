{
  "manifest_version": 3,
  "name": "Receipt",
  "version": "2.1.0",
  "description": "Your daily browser receipt. See exactly where your time goes — and share the truth.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "notifications",
    "idle",
    "alarms"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["blocker.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "Receipt - 오늘의 영수증"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://octxxiii.github.io/*",
      "http://localhost:*/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "author": "Receipt",
  "homepage_url": "https://octxxiii.github.io/tab-timer",
  "short_name": "Receipt",
  "offline_enabled": true,
  "minimum_chrome_version": "88"
}
