{
  "name": "tab-timer-extension",
  "version": "2.0.0",
  "description": "A Chrome extension to track time spent on different tabs",
  "main": "background.js",
  "scripts": {
    "test": "jest --detectOpenHandles",
    "test:coverage": "jest --coverage",
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js && echo 'Watching for changes...' && chokidar 'src/**/*' 'public/**/*' -c 'npm run build'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "chrome-extension",
    "time-tracking",
    "productivity"
  ],
  "author": "Tab Timer Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octxxiii/tab-timer.git"
  },
  "bugs": {
    "url": "https://github.com/octxxiii/tab-timer/issues"
  },
  "homepage": "https://github.com/octxxiii/tab-timer#readme",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/plugin-transform-runtime": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/runtime": "^7.22.0",
    "babel-jest": "^29.0.0",
    "babel-loader": "^9.1.2",
    "css-loader": "^6.8.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-puppeteer": "^9.0.2",
    "jsdom": "^22.0.0",
    "puppeteer": "^24.6.1",
    "sharp": "^0.34.5",
    "style-loader": "^3.3.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "directories": {
    "test": "tests"
  }
}
